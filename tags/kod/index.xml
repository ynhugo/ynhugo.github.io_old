&lt;/span&gt;&lt;/span&gt;&lt;span class=&#34;line&#34;&gt;&lt;span class=&#34;cl&#34;&gt;yes n &lt;span class=&#34;p&#34;&gt;|&lt;/span&gt; termux-setup-storage
